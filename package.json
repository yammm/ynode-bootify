{
    "name": "@ynode/bootify",
    "version": "1.7.2",
    "description": "A standardized Fastify application bootstrapper with built-in cluster management, graceful shutdown, and configuration wiring for the @ynode ecosystem.",
    "main": "src/plugin.js",
    "types": "index.d.ts",
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./src/plugin.js",
            "default": "./src/plugin.js"
        }
    },
    "type": "module",
    "license": "MIT",
    "author": "Michael Welter <me@mikinho.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/yammm/ynode-bootify.git"
    },
    "bugs": {
        "url": "https://github.com/yammm/ynode-bootify/issues"
    },
    "homepage": "https://github.com/yammm/ynode-bootify#readme",
    "keywords": [
        "fastify",
        "fastify-plugin",
        "bootstrap",
        "framework",
        "cluster",
        "process-manager",
        "graceful-shutdown",
        "zero-downtime",
        "lifecycle",
        "startup",
        "signal-handling",
        "pidfile",
        "ynode"
    ],
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^1.2.0",
        "@eslint/markdown": "^8.0.1",
        "@mikinho/autover": "^2.1.0",
        "auto-changelog": "^2.5.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "fastify": "^5.8.4",
        "globals": "^17.4.0",
        "jsdoc": "^4.0.5",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.3",
        "yargs": "^18.0.0"
    },
    "scripts": {
        "changelog": "auto-changelog -p",
        "docs": "node scripts/gen-docs.mjs",
        "docs:clean": "rimraf docs jsdoc.json || (rmdir /s /q docs 2> NUL & del /f /q jsdoc.json 2> NUL) || true",
        "docs:open": "node -e \"import('node:child_process').then(m=>m.exec(process.platform==='win32'?'start docs/index.html':(process.platform==='darwin'?'open docs/index.html':'xdg-open docs/index.html')))\"",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "ver:preview": "npx autover --no-amend --dry-run --short",
        "ver:apply": "npx autover --guard-unchanged --short",
        "test": "node --test",
        "prepublishOnly": "npm test && npm run lint",
        "postversion": "git push && git push --tags"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "src",
        "index.d.ts",
        "README.md",
        "LICENSE"
    ],
    "dependencies": {
        "@ynode/autoshutdown": "^1.6.3",
        "@ynode/cluster": "^1.7.3",
        "@ynode/ylog": "^1.3.3",
        "mkpidfile": "^1.0.1",
        "proxiable": "^1.0.4"
    },
    "peerDependencies": {
        "fastify": "5.x"
    }
}
